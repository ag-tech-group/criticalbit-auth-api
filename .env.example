# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/criticalbit_auth

# Auth - generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-change-in-production

# Environment
ENVIRONMENT=development

# CORS — comma-separated additional origins (*.criticalbit.gg is always allowed in production)
CORS_ORIGINS=

# Frontend URL (auth frontend for redirects after OAuth callbacks)
FRONTEND_URL=http://localhost:5173

# Cookie domain — set to .criticalbit.gg in production (works on all subdomains)
# Leave empty for localhost development
COOKIE_DOMAIN=

# Logging
LOG_LEVEL=INFO

# OpenTelemetry (disabled by default)
OTEL_ENABLED=false
OTEL_SERVICE_NAME=criticalbit-auth-api
OTEL_EXPORTER_ENDPOINT=http://localhost:4317

# Feature flags — prefix with FEATURE_ and set to true/false
# FEATURE_NEW_DASHBOARD=true
# FEATURE_BETA_EXPORT=false
